# ════════════════════════════════════════════════════════════════════════════════
# UNITARYX PRODUCTION STACK - PORTAINER/GITOPS CONFIGURATION
# ════════════════════════════════════════════════════════════════════════════════
# 
# INSTRUCTIONS:
# 1. Copy this file to .env in your deployment directory
# 2. Update all REQUIRED fields marked with [REQUIRED]
# 3. Use strong passwords for production (min 16 chars, mixed case, numbers, symbols)
# 4. In Portainer: Stacks > Add Stack > Upload docker-compose.yml + set env vars
# 5. For GitOps: Store this file in a secrets manager (e.g., .env in encrypted repo)
# 
# ════════════════════════════════════════════════════════════════════════════════

# ────────────────────────────────────────────────────────────────────────────────
# DOCKER & COMPOSE SETTINGS
# ────────────────────────────────────────────────────────────────────────────────
COMPOSE_PROJECT_NAME=unitaryx
REGISTRY=your-registry.azurecr.io/unitaryx
APP_VERSION=latest

# Container Network Configuration
# NETWORK_SUBNET is optional. Docker will auto-assign an available subnet
# for the project network when `ipam` is not set in docker-compose.yml.
# Uncomment and set only if you need a specific subnet on a dedicated host.
# NETWORK_SUBNET=172.25.0.0/16

# Volume Mount Paths (where Docker stores persistent data)
# Update these paths based on your server's storage configuration
DB_VOLUME_PATH=/path/to/docker-host/db
APP_VOLUME_PATH=/path/to/docker-host/app
APP_BACKUP_PATH=/path/to/docker-host/backups

# ────────────────────────────────────────────────────────────────────────────────
# TIMEZONE SETTINGS
# ────────────────────────────────────────────────────────────────────────────────
TZ=Asia/Kolkata

# ────────────────────────────────────────────────────────────────────────────────
# POSTGRESQL DATABASE CONFIGURATION [REQUIRED]
# ────────────────────────────────────────────────────────────────────────────────
# IMPORTANT: After initial setup, keep POSTGRES_PASSWORD the same.
# Changing it requires manual database user password update.

POSTGRES_USER=unitaryx
POSTGRES_PASSWORD=generate_strong_password_here_16_chars_min
POSTGRES_DB=unitaryx
DB_HOST=db
DB_PORT=5432

# Database tuning for different deployment scales
# For small deployments (1-5 users): defaults are fine
# For medium deployments (5-50 users): increase shared_buffers to 512MB
# For large deployments (50+ users): increase to 1GB
POSTGRES_INITDB_ARGS=-c shared_buffers=256MB -c effective_cache_size=1GB -c max_connections=200

# Database port exposed outside the container (for backup/monitoring)
POSTGRES_PORT=5433

# Optional: Explicitly set DATABASE_URL (overrides components above)
# Format: postgresql+psycopg://user:password@host:port/database
# Leave empty to auto-construct from components above
DATABASE_URL=

# Database resource limits (adjust based on your infrastructure)
DB_CPU_LIMIT=1
DB_CPU_RESERVE=0.5
DB_MEMORY_LIMIT=512M
DB_MEMORY_RESERVE=256M

# ────────────────────────────────────────────────────────────────────────────────
# APPLICATION CONFIGURATION [REQUIRED]
# ────────────────────────────────────────────────────────────────────────────────
# Application port (must be unique if multiple stacks on same host)
APP_PORT=10003

# Flask debug mode (NEVER True in production)
DEBUG=False

# Security: Secret key for Flask sessions (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=generate_a_random_secret_key_here_min_32_chars

# ────────────────────────────────────────────────────────────────────────────────
# ADMIN CREDENTIALS [REQUIRED] - CHANGE IMMEDIATELY AFTER FIRST LOGIN
# ────────────────────────────────────────────────────────────────────────────────
ADMIN_EMAIL=admin@unitaryx.com
ADMIN_PASS=AdminPasswordHere!ChangeImmediately
SUPERADMIN_EMAIL=superadmin@example.com
SUPERADMIN_PASSWORD=SuperAdminPasswordHere!ChangeImmediately
SUPERADMIN_NAME=Super Admin

# ────────────────────────────────────────────────────────────────────────────────
# GUNICORN APPLICATION SERVER TUNING
# ────────────────────────────────────────────────────────────────────────────────
# Adjust based on your server CPU cores and expected concurrent users
# Formula: Workers = (2 * CPU_cores) + 1
# For 4 CPU cores: GUNICORN_WORKERS=9

GUNICORN_WORKERS=2
GUNICORN_THREADS=4
GUNICORN_TIMEOUT=120

# Application resource limits
APP_CPU_LIMIT=2
APP_CPU_RESERVE=1
APP_MEMORY_LIMIT=1G
APP_MEMORY_RESERVE=512M

# ────────────────────────────────────────────────────────────────────────────────
# GOOGLE OAUTH CONFIGURATION (Optional)
# ────────────────────────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/
# Leave empty to disable Google login

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_ALLOWED_ORIGINS=https://unitaryx.org

# ────────────────────────────────────────────────────────────────────────────────
# EMAIL/SMTP CONFIGURATION [REQUIRED for password reset]
# ────────────────────────────────────────────────────────────────────────────────
# Gmail setup:
# 1. Enable 2FA on Google Account
# 2. Generate App Password: https://myaccount.google.com/apppasswords
# 3. Use app password as SMTP_PASS

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=noreply@unitaryx.org
SMTP_USE_TLS=True

# ────────────────────────────────────────────────────────────────────────────────
# REVERSE PROXY / TRAEFIK CONFIGURATION (Optional)
# ────────────────────────────────────────────────────────────────────────────────
# Enable Traefik integration if you have Traefik deployed
TRAEFIK_ENABLE=false
TRAEFIK_HOST=unitaryx.example.com
